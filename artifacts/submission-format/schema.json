{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-challenge.local/submission.schema.json",
  "title": "AI Challenge 2026 - Submission",
  "type": "object",
  "required": ["query_id", "team_id", "submitted_at", "results"],
  "properties": {
    "query_id": {
      "type": "string",
      "description": "Identifier of the query as announced by the jury, e.g. 'Q01'."
    },
    "team_id": {
      "type": "string",
      "description": "Team identifier assigned by the organizer."
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp with timezone offset, e.g. 2026-09-15T10:23:11.456+07:00."
    },
    "method_note": {
      "type": "string",
      "description": "Short description of the method used (free text, <= 280 chars)."
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rank", "video_id"],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based rank within this submission."
          },
          "video_id": {
            "type": "string",
            "description": "Video identifier such as 'L01_V001'."
          },
          "frame_idx": {
            "type": "integer",
            "minimum": 0,
            "description": "Absolute frame index inside the source video."
          },
          "timestamp_ms": {
            "type": "integer",
            "minimum": 0,
            "description": "Time in milliseconds from the start of the video."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Optional model confidence."
          }
        },
        "anyOf": [
          { "required": ["frame_idx"] },
          { "required": ["timestamp_ms"] }
        ]
      }
    }
  },
  "additionalProperties": false
}
