# ===== Data paths =====
DATA_ROOT=./data
MODEL_CACHE_DIR=./data/models
HF_HOME=./data/models/huggingface

# ===== Backend =====
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ===== Index / Retrieval =====
CLIP_MODEL=open_clip:ViT-L-14/laion2b_s32b_b82k
CLIP_INDEX_PATH=./data/index/clip_vit_l14
BM25_INDEX_PATH=./data/index/bm25
DEFAULT_TOP_K=100
SEARCH_DEVICE=cuda

# ===== LLM providers (optional) =====
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
LLM_RERANK_MODEL=gpt-4o-mini

# ===== Local LLM fallback =====
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ===== Submission to organizer =====
AICHALLENGE_SUBMIT_URL=
AICHALLENGE_TEAM_ID=
AICHALLENGE_TEAM_TOKEN=

# ===== Frontend (read by Next.js / Once UI) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_KEYFRAMES_BASE_URL=http://localhost:8000/static/keyframes
NEXT_PUBLIC_DEFAULT_THEME=dark
